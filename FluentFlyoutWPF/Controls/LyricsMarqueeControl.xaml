<UserControl x:Class="FluentFlyout.Controls.LyricsMarqueeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Height="40" Width="300"
             ClipToBounds="True"
             TextOptions.TextRenderingMode="ClearType" TextOptions.TextFormattingMode="Ideal"
             FontFamily="Segoe UI Variable, Microsoft YaHei, Microsoft JhengHei, MS Gothic"
             FlowDirection="LeftToRight">
    <Grid Name="MarqueeGrid" Background="Transparent" ClipToBounds="True">
        <TextBlock Name="MarqueeText"
                   Text=""
                   FontSize="{Binding LyricsFontSize}"
                   FontFamily="{Binding LyricsFontFamily}"
                   FontWeight="Normal"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="0"
                   Opacity="0.85">
            <TextBlock.RenderTransform>
                <TranslateTransform x:Name="MarqueeTranslate" X="0" Y="0" />
            </TextBlock.RenderTransform>
        </TextBlock>
    </Grid>
</UserControl>
